NODE_ENV=development
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGIN=*
REQUEST_BODY_LIMIT=1mb
UPLOAD_MAX_BYTES=1048576
DNS_LOOKUP_TIMEOUT_MS=10000
SMTP_TIMEOUT_MS=8000
SMTP_RETRIES=2
SMTP_PORT=25
SMTP_HELO_HOST=bulk-email-verifier.local
SMTP_MAIL_FROM=verifier@bulk-email-verifier.local
ABSTRACT_API_KEY=your_abstract_api_key_here
ABSTRACT_API_TIMEOUT_MS=8000
ABSTRACT_API_MONTHLY_LIMIT=100
ABSTRACT_API_WARNING_THRESHOLD=10
ABSTRACT_API_THROTTLE_MS=1000
VERIFICATION_CONCURRENCY=25

# Frontend builds use same-origin API by default in production.
# For separate frontend/backend hosts, set this during Parcel build.
API_BASE_URL=
